# Development overrides — copy to .env.development and adjust as needed.
# start.sh sources this file when run as `./start.sh` (default mode is dev).

DEBUG=True

# Path to the skill repository (defaults to <repo>/skill_repo if unset).
SKILL_REPO_PATH=./skill_repo

# Install targets — three local-type fakes so the /installed/ UI has
# enough state to exercise multi-section layout. F15 and F20 are 'local'
# in dev (no SSH keys / hosts) so the same code paths work without
# real infrastructure. After editing your local .env.development, restart
# start.sh, then populate fixtures:
#   venv/Scripts/python.exe scripts/seed-installed-dev.py
# To remove fixtures:
#   venv/Scripts/python.exe scripts/seed-installed-dev.py --clean
INSTALL_TARGET_F12_TYPE=local
INSTALL_TARGET_F12_BASE=/tmp/skills-dev/{user_name}/skills
INSTALL_TARGET_F15_TYPE=local
INSTALL_TARGET_F15_BASE=/tmp/skills-dev-f15/{user_name}/skills
INSTALL_TARGET_F20_TYPE=local
INSTALL_TARGET_F20_BASE=/tmp/skills-dev-f20/{user_name}/skills

# Default user identity for the /installed/ page in dev. The frontend reads
# CURRENT_USER_NAME from the cookie at runtime; set the cookie in DevTools
# (Application → Cookies → http://127.0.0.1:3000) to "dev" to match the
# seeder script default.
DEV_USER_NAME=dev
