# Reference of all supported environment variables.
#
# In practice, copy .env.development.example -> .env.development or
# .env.production.example -> .env.production. start.sh sources the file
# matching the mode you run (`./start.sh` -> .env.development,
# `./start.sh prod` -> .env.production).

# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-me-with-a-strong-random-secret

DEBUG=False

# Comma-separated hostnames the server will respond to.
ALLOWED_HOSTS=localhost,127.0.0.1

# Port the dev server / gunicorn binds to.
PORT=3000

# Origin(s) allowed to call /api/* from a browser. Default '*' opens the API
# to any origin (suitable for unauthenticated internal tools). Browsers do
# not support a comma-separated list.
CORS_ALLOWED_ORIGINS=*

# Path to the skill repository (defaults to <repo>/skill_repo if unset).
SKILL_REPO_PATH=./skill_repo

# Path to the frontend directory (defaults to <repo>/frontend if unset).
# index.html / skill.html are read from here at request time, and
# assets/ vendor/ are picked up by collectstatic.
FRONTEND_DIR=./frontend
