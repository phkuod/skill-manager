# Reference of all supported environment variables.
#
# In practice, copy .env.development.example -> .env.development or
# .env.production.example -> .env.production. start.sh sources the file
# matching the mode you run (`./start.sh` -> .env.development,
# `./start.sh prod` -> .env.production).

# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-me-with-a-strong-random-secret

DEBUG=False

# Comma-separated hostnames the server will respond to.
ALLOWED_HOSTS=localhost,127.0.0.1

# Port the dev server / gunicorn binds to.
PORT=3000

# Origin(s) allowed to call /api/* from a browser. Default '*' opens the API
# to any origin (suitable for unauthenticated internal tools). Browsers do
# not support a comma-separated list.
CORS_ALLOWED_ORIGINS=*

# Path to the skill repository (defaults to <repo>/skill_repo if unset).
SKILL_REPO_PATH=./skill_repo

# ---------------------------------------------------------------------------
# Install targets (one-click install feature)
# ---------------------------------------------------------------------------
# Each install target is a group of INSTALL_TARGET_<NAME>_* keys. <NAME>
# appears verbatim in the UI ("Install to F12"). Allowed: A-Z, 0-9.
#
# Required fields:
#   _TYPE     'local' (filesystem on this host) or 'ssh' (rsync over SSH)
#   _BASE     Target dir; SHOULD include the {user_name} placeholder.
#             WARNING: if _BASE has no {user_name}, every user will install
#             to the same directory and overwrite each other's work. Always
#             include {user_name} unless you have a specific reason not to.
#
# ssh-only fields:
#   _HOST     Remote host (DNS or IP)
#   _USER     SSH login user
#   _SSH_KEY  Absolute path to private key file (passwordless, BatchMode)
#
# Hard timeout for any single install (local copy or rsync). Default 60s.
# INSTALL_TIMEOUT_SECONDS=60

# Example layout (uncomment and edit per environment):
# INSTALL_TARGET_F12_TYPE=local
# INSTALL_TARGET_F12_BASE=/AAA/{user_name}/skills
#
# INSTALL_TARGET_F15_TYPE=ssh
# INSTALL_TARGET_F15_BASE=/AAA/{user_name}/skills
# INSTALL_TARGET_F15_HOST=f15.intra.example
# INSTALL_TARGET_F15_USER=svc-skillmarket
# INSTALL_TARGET_F15_SSH_KEY=/etc/ssh/skillmarket_id_rsa
