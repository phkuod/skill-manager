# Production overrides — copy to .env.production and edit before deploying.
# start.sh sources this file when run as `./start.sh prod`.

# REQUIRED. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-me-with-a-strong-random-secret

# Comma-separated hostnames the server will respond to.
# Must include the host/IP the API is reached at from clients.
ALLOWED_HOSTS=10.234.56.78,localhost,127.0.0.1

DEBUG=False

# Port gunicorn binds to (0.0.0.0:$PORT).
PORT=9419

# Origin allowed to call /api/* from a browser. Default '*' opens the API to
# any origin — fine for an unauthenticated internal tool. Set to a single
# origin (e.g. 'http://skills.intra.example') to lock it down. Browsers do
# not accept a comma-separated list here.
CORS_ALLOWED_ORIGINS=*

# Path to the skill repository (defaults to <repo>/skill_repo if unset).
# Recommend an absolute path in production.
SKILL_REPO_PATH=/srv/skill-market/skill_repo

# Install targets — prod values. Replace example host / user / key path.
INSTALL_TARGET_F12_TYPE=local
INSTALL_TARGET_F12_BASE=/AAA/{user_name}/skills

INSTALL_TARGET_F15_TYPE=ssh
INSTALL_TARGET_F15_BASE=/AAA/{user_name}/skills
INSTALL_TARGET_F15_HOST=f15.intra.example
INSTALL_TARGET_F15_USER=svc-skillmarket
INSTALL_TARGET_F15_SSH_KEY=/etc/ssh/skillmarket_id_rsa
